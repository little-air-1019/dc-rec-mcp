{
  "name": "dc-rec-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "Discord voice-channel recording MCP server. Reuses Craig's recording + cook pipeline; an external caller handles transcription, summary, and publishing.",
  "license": "ISC",
  "type": "commonjs",
  "main": "dist/index.js",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=22.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "eris": "^0.18.0",
    "zod": "^4.4.3"
  }
}
